#!/usr/bin/env bash
#
# aibox-claude — run Claude Code inside the aibox-claude container.
#
# Each "profile" is an isolated config sandbox on the host:
#
#   $AIBOX_CONFIG_ROOT/
#     └── <profile>/
#           ├── base        # endpoint config inherited by every relay
#           ├── envs/       # relay endpoints; pick one every run with -e <name>
#           │     ├── openrouter
#           │     └── <relay>…
#           └── home/       # mounted as /home/claude (creds, history, skills…)
#
# Everything is per-profile. `base` holds the shared endpoint settings; each
# relay under envs/ inherits base and overrides only what it sets (set a key
# to an empty value to blank out a base default). There is no default
# endpoint — every run picks a relay:
#     aibox-claude -e openrouter        aibox-claude -e some-relay
#
# On a profile's first run, a status line (aibox-claude-status.sh, alongside
# this script) is seeded into home/.claude/; an existing one is left untouched.
#
# The project you want to work on is mounted read-write at /work.
#
# The container IS the sandbox boundary, so claude runs with ALL permission
# prompts skipped by default — the agent can do whatever it likes inside.
# Pass --safe when you'd rather have the normal per-action prompts back.
#
# Usage:
#   aibox-claude [options] [-- <args passed straight to claude>]
#   aibox-claude sync [base|<relay>] [--dry-run]   # refresh template docs
#
# `sync` rewrites a file's doc/example comments to the current template while
# keeping every real config line you added (re-placed under its example; any
# whose example is gone is kept in a trailing block). No arg syncs base + all
# relays; --dry-run prints the result instead of writing.
#
# Options:
#   -c, --config <profile>   Config profile name         (default: "default")
#   -e, --env    <name|path> Relay endpoint (REQUIRED): a name under
#                            <profile>/envs/, or a path. Merged onto `base`.
#   -w, --work   <dir>       Project dir mounted at /work (default: $PWD)
#   -m, --mount  <spec>      Extra bind mount, docker syntax host:container[:ro]
#                            (repeatable; e.g. shared read-only skills)
#   -s, --shell              Open a bash shell instead of launching claude
#       --safe               Keep claude's normal permission prompts (default
#                            is to skip them — the container is the sandbox)
#       --build              Rebuild the image from scratch before running.
#                            Forces --no-cache --pull: the base image is
#                            re-pulled and the "latest" Node/Go/Claude versions
#                            are re-resolved (a plain cached build would freeze
#                            them at first-build values). This is the way to
#                            upgrade. Slow — it rebuilds every layer.
#       --no-net             Disable networking (only useful for offline tasks)
#   -h, --help               Show this help
#
# Examples:
#   aibox-claude --build                         # first-time build / upgrade
#   aibox-claude -c risky -w ~/code/sketchy-repo # run in the "risky" profile
#   aibox-claude -e openrouter                   # default profile, openrouter relay
#   aibox-claude --safe                          # keep the permission prompts
#   aibox-claude -c risky -s                     # poke around with a shell

set -euo pipefail

IMAGE="${AIBOX_IMAGE:-aibox-claude:latest}"
CONFIG_ROOT="${AIBOX_CONFIG_ROOT:-$HOME/.aibox/claude}"
# Bump when a template below changes. Existing env files carry the version they
# were written with (first-line `# aibox-template: vN`); a run whose file lags
# this prints a hint to `sync`, which refreshes the docs and keeps your config.
TEMPLATE_VERSION=3
# Resolve our own location, following symlinks, so the Dockerfile is found even
# when invoked through a symlink on $PATH (e.g. ~/.local/bin/aibox-claude ->
# this file). Portable: no `readlink -f`, which BSD/macOS readlink lacks.
src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
done
SCRIPT_DIR="$(cd -P "$(dirname "$src")" && pwd)"
DOCKERFILE="$SCRIPT_DIR/aibox-claude.Dockerfile"

profile=default
env_name=
workdir="$PWD"
open_shell=0
do_build=0
no_net=0
safe=0
declare -a extra_mounts=()
declare -a claude_args=()

# Print the leading comment block (up to the first blank line) as help text,
# so the usage output stays in sync with the header no matter how it grows.
usage() { sed -n '3,/^$/p' "$src" | sed 's/^#\( \|$\)//'; }

# --- env-file templates (single source, shared by scaffold and sync) --------
# Both begin with a `# aibox-template: vN` stamp so `sync` can tell a file's
# vintage. Everything is a comment: each key is documented, then shown as a
# commented #EXAMPLE. You set one by adding a real line under its example.
emit_base_template() {
    printf '# aibox-template: v%s\n' "$TEMPLATE_VERSION"
    cat <<'EOF'
# base — shared config inherited by every relay under envs/.
# A relay (-e <name>) is merged ON TOP of this file; a key set there wins.
# docker --env-file format: KEY=VALUE, one per line.

# Each item is documented, then shown as a commented #EXAMPLE. To set one, add
# a real line under its example — leave the example itself as living reference.

# Model tiers: claude shells out to the haiku tier for background work and
# resolves sonnet/opus via subagents or /model. Map every tier to a model your
# relays serve; a relay that differs overrides just that line.
#ANTHROPIC_DEFAULT_HAIKU_MODEL=replace-with-small-fast-model
#ANTHROPIC_DEFAULT_SONNET_MODEL=replace-with-mid-model
#ANTHROPIC_DEFAULT_OPUS_MODEL=replace-with-main-model

# Fable is a real fourth tier, only used if you /model to it; many relays don't
# serve it — set it only if yours does.
#ANTHROPIC_DEFAULT_FABLE_MODEL=replace-with-fable-model
EOF
}

emit_relay_template() {
    printf '# aibox-template: v%s\n' "$TEMPLATE_VERSION"
    printf '# %s — relay endpoint, merged onto ../base (this file wins).\n' "$1"
    cat <<'EOF'
# docker --env-file format: KEY=VALUE. Each item is documented, then shown as a
# commented #EXAMPLE — add a real line under the example to set it.

# REQUIRED. base_url of your provider (claude's /v1/messages root).
#ANTHROPIC_BASE_URL=https://your-provider.example.com/anthropic

# REQUIRED. API key / auth token.
#ANTHROPIC_AUTH_TOKEN=sk-replace-me

# Override any base model tier here when this relay serves a different model.
# Set only the tiers that differ; unset ones fall through to base.
#ANTHROPIC_DEFAULT_HAIKU_MODEL=this-relays-small-model
#ANTHROPIC_DEFAULT_SONNET_MODEL=this-relays-mid-model
#ANTHROPIC_DEFAULT_OPUS_MODEL=this-relays-big-model
#ANTHROPIC_DEFAULT_FABLE_MODEL=this-relays-fable-model
EOF
}

# --- sync: refresh a file's docs to the current template, keep your config ---
# First-line `# aibox-template: vN` -> N (0 if unstamped/pre-versioning).
file_template_version() {
    local v
    v="$(sed -n '1s/^# aibox-template: v\([0-9][0-9]*\).*/\1/p' "$1" 2>/dev/null)"
    printf '%s' "${v:-0}"
}

# Emit the given file rewritten against a freshly generated template: doc and
# example lines come from the template; every real (uncommented KEY=VALUE) line
# from the old file is preserved and re-placed directly under its matching
# #KEY= example. Real keys with no matching example are appended in a trailing
# block so nothing is lost. Prints to stdout; the caller decides whether to
# write. awk owns the merge (its associative arrays sidestep bash 3.2).
sync_file() {
    local old="$1"; shift
    "$@" | awk '
        # First arg: old file — collect real KEY=VALUE lines (last wins per key).
        FNR==NR {
            s=$0; sub(/^[ \t]+/,"",s)
            if (s ~ /^#/ || s=="") next
            eq=index(s,"="); if (eq==0) next
            key=substr(s,1,eq-1)
            if (!(key in have)) { order[++n]=key; have[key]=1 }
            val[key]=s
            next
        }
        # Second input (stdin): the fresh template. Echo it; after each #KEY=
        # example, drop in the matching real line if we have one.
        {
            print
            if ($0 ~ /^#[A-Za-z_][A-Za-z0-9_]*=/) {
                k=substr($0,2); k=substr(k,1,index(k,"=")-1)
                if (k in have && !(k in done)) { print val[k]; done[k]=1 }
            }
        }
        END {
            first=1
            for (i=1;i<=n;i++) {
                k=order[i]
                if (k in done) continue
                if (first) {
                    print ""
                    print "# --- settings kept from your old file (no matching example above) ---"
                    first=0
                }
                print val[k]
            }
        }
    ' "$old" -
}

# Sync one file in place (or to stdout under --dry-run). Trailing args are the
# template-emitter command for that file.
sync_one() {
    local file="$1"; shift
    if [[ ! -f "$file" ]]; then
        echo "!! not found, skipping: $file" >&2
        return
    fi
    local result
    result="$(sync_file "$file" "$@")"
    if (( dry_run )); then
        printf '===== %s =====\n%s\n\n' "$file" "$result"
    else
        printf '%s\n' "$result" > "$file"
        chmod 600 "$file"
        echo ">> synced $file -> template v$TEMPLATE_VERSION" >&2
    fi
}

subcmd=
sync_target=
dry_run=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        sync)         subcmd=sync; shift
                      [[ $# -gt 0 && "$1" != -* ]] && { sync_target="$1"; shift; } ;;
        --dry-run)    dry_run=1; shift ;;
        -c|--config)  profile="$2"; shift 2 ;;
        -e|--env)     env_name="$2"; shift 2 ;;
        -w|--work)    workdir="$2";  shift 2 ;;
        -m|--mount)   extra_mounts+=("$2"); shift 2 ;;
        -s|--shell)   open_shell=1; shift ;;
        --safe)       safe=1; shift ;;
        --build)      do_build=1; shift ;;
        --no-net)     no_net=1; shift ;;
        -h|--help)    usage; exit 0 ;;
        --)           shift; claude_args+=("$@"); break ;;
        *)            claude_args+=("$1"); shift ;;
    esac
done

# --- explicit build --------------------------------------------------------
# --build always (re)builds; a missing image is also auto-built just before the
# real run below, so the scaffold-and-stop path never builds for nothing.
#
# --no-cache --pull is deliberate: the Node/Go layers resolve "latest" at build
# time via curl, but their RUN text never changes, so a cached build would skip
# the resolution and freeze the versions at whatever the first build saw. Full
# rebuild + fresh base image is the only way an explicit --build actually picks
# up new upstream versions. Slower, but --build means "I want current".
if (( do_build )); then
    echo ">> building $IMAGE (no cache, pulling fresh base) ..."
    docker build --no-cache --pull -f "$DOCKERFILE" -t "$IMAGE" "$SCRIPT_DIR"
fi

# --- resolve profile paths -------------------------------------------------
# Everything is per-profile. `base` is the shared endpoint config; each relay
# under envs/ is merged on top of it (relay wins). home/ is durable state.
profile_dir="$CONFIG_ROOT/$profile"
home_dir="$profile_dir/home"
envs_dir="$profile_dir/envs"
base_file="$profile_dir/base"

# --- sync: refresh template docs in place, keeping your real config ----------
# `sync base` -> just base; `sync <relay>` -> one relay; `sync` -> base + every
# relay under envs/. --dry-run prints the result instead of writing.
if [[ "$subcmd" == sync ]]; then
    case "$sync_target" in
        "")     sync_one "$base_file" emit_base_template
                for f in "$envs_dir"/*; do
                    [[ -f "$f" ]] && sync_one "$f" emit_relay_template "$(basename "$f")"
                done ;;
        base)   sync_one "$base_file" emit_base_template ;;
        *)      sync_one "$envs_dir/$sync_target" emit_relay_template "$sync_target" ;;
    esac
    exit 0
fi

mkdir -p "$home_dir"

# Seed the status line into a fresh profile home. The home mount shadows the
# image, so config has to land here, not in the Dockerfile. First use only:
# an existing script or settings is left alone, so customizations survive.
status_src="$SCRIPT_DIR/aibox-claude-status.sh"
if [[ -f "$status_src" ]]; then
    claude_dir="$home_dir/.claude"
    mkdir -p "$claude_dir"
    status_dst="$claude_dir/aibox-claude-status.sh"
    [[ -f "$status_dst" ]] || install -m 644 "$status_src" "$status_dst"
    [[ -f "$claude_dir/settings.json" ]] || cat > "$claude_dir/settings.json" <<'EOF'
{
  "statusLine": {
    "type": "command",
    "command": "bash /home/claude/.claude/aibox-claude-status.sh"
  }
}
EOF
fi

# --- a relay is required ----------------------------------------------------
# There is no default endpoint: every run picks one with -e. A bare --build is
# the one exception — it built above, so just report and stop.
if [[ -z "$env_name" ]]; then
    if (( do_build )); then
        echo ">> image built. run it with a relay: aibox-claude -e <name>" >&2
        exit 0
    fi
    echo "!! no relay selected — pick one with -e <name>:" >&2
    if relays=$(ls -1 "$envs_dir" 2>/dev/null) && [[ -n "$relays" ]]; then
        sed 's/^/     /' <<<"$relays" >&2
    else
        echo "     (none yet — run  aibox-claude -e <name>  to scaffold one)" >&2
    fi
    exit 1
fi

# A bare name lives under this profile's envs/; a value with a slash or a .env
# suffix is taken as an explicit path (never scaffolded).
if [[ "$env_name" == */* || "$env_name" == *.env ]]; then
    env_file="$env_name"; named=0
else
    env_file="$envs_dir/$env_name"; named=1
fi

# First use of a named relay: scaffold `base` (once) plus a relay stub, then
# stop so credentials can be filled in.
if [[ ! -f "$env_file" ]]; then
    if (( ! named )); then
        echo "!! env file not found: $env_file" >&2
        exit 1
    fi
    mkdir -p "$envs_dir"
    [[ -f "$base_file" ]] || { emit_base_template > "$base_file"; chmod 600 "$base_file"; }
    emit_relay_template "$env_name" > "$env_file"
    chmod 600 "$env_file"
    echo ">> scaffolded $base_file and $env_file"
    echo ">> edit the credentials, then re-run: aibox-claude -e $env_name"
    exit 0
fi

# Nudge (don't touch the file) when base or the relay predates the current
# template, so stale docs can be refreshed with `sync` when convenient.
for f in "$base_file" "$env_file"; do
    [[ -f "$f" ]] || continue
    fv="$(file_template_version "$f")"
    if (( fv < TEMPLATE_VERSION )); then
        echo ">> $f is template v$fv (current v$TEMPLATE_VERSION) — refresh docs with: aibox-claude sync ${f##*/}" >&2
    fi
done

# --- build if the image is missing -----------------------------------------
# Cached on purpose (no --no-cache/--pull): this only fires to get a runnable
# image when there's none, so speed wins. It may reuse stale layers and produce
# an older version than upstream — that's fine here. Upgrading is --build's job.
if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
    echo ">> building $IMAGE ..."
    docker build -f "$DOCKERFILE" -t "$IMAGE" "$SCRIPT_DIR"
fi

# --- merge base + relay into one env file ----------------------------------
# docker's precedence across multiple --env-file flags is unspecified, so we
# merge ourselves: later files win per key, and a KEY= line overrides a base
# default with an empty value. Comments and blank lines are dropped. The result
# is a 0600 temp file (host-side only, never mounted) removed on exit.
merged_env="$(mktemp "${TMPDIR:-/tmp}/aibox-env.XXXXXX")"
chmod 600 "$merged_env"
# We can't `exec docker` below: an exec would replace this shell and the EXIT
# trap would never fire, leaking this 0600 credentials file into /tmp. So docker
# runs as a child and we clean up on any exit (normal, Ctrl-C, or kill).
trap 'rm -f "$merged_env"' EXIT INT TERM
declare -a env_srcs=()
[[ -f "$base_file" ]] && env_srcs+=("$base_file")
env_srcs+=("$env_file")
awk '
    /^[ \t]*#/ { next }
    /^[ \t]*$/ { next }
    {
        s = $0; sub(/^[ \t]+/, "", s)
        eq = index(s, "=")
        key = (eq > 0) ? substr(s, 1, eq - 1) : s
        if (!(key in seen)) { order[++n] = key; seen[key] = 1 }
        val[key] = s
    }
    END { for (i = 1; i <= n; i++) print val[order[i]] }
' "${env_srcs[@]}" > "$merged_env"

# --- assemble docker run ---------------------------------------------------
declare -a run_args=(--rm --env-file "$merged_env")

# Interactive TTY only when we actually have one (so pipes still work).
if [[ -t 0 && -t 1 ]]; then run_args+=(-it); else run_args+=(-i); fi

# On Linux, run as the host uid/gid so files created in /work stay yours.
# Docker Desktop (macOS) maps ownership automatically, so skip it there.
if [[ "$(uname)" == "Linux" ]]; then
    run_args+=(--user "$(id -u):$(id -g)")
fi

# Hardening: no privilege escalation, drop all Linux capabilities. A Node
# process needs none of them, and the mounts stay writable regardless.
run_args+=(--security-opt no-new-privileges --cap-drop ALL)

if (( no_net )); then
    run_args+=(--network none)
elif [[ "$(uname)" == "Linux" ]]; then
    # Docker Desktop resolves host.docker.internal for free; native Linux does
    # not. Map it so a relay/proxy on the host (LiteLLM, claude-code-router…)
    # is reachable the same way from either OS.
    run_args+=(--add-host host.docker.internal:host-gateway)
fi

# Mounts: isolated home + the project at /work + any extras.
run_args+=(-v "$home_dir:/home/claude")
run_args+=(-v "$workdir:/work" -w /work)
# macOS bash 3.2 treats an empty array as "unbound" under `set -u`; the
# ${arr[@]+…} guard expands to nothing when extra_mounts is empty.
for m in ${extra_mounts[@]+"${extra_mounts[@]}"}; do run_args+=(-v "$m"); done

if (( open_shell )); then
    docker run "${run_args[@]}" --entrypoint /bin/bash "$IMAGE"
    exit
fi

# Wide-open by default: the container is the boundary, so let the agent skip
# every permission prompt. --safe puts the normal prompts back. Prepended so
# an explicit flag in claude_args (e.g. --permission-mode) still wins.
declare -a claude_cmd=()
if (( ! safe )); then
    claude_cmd+=(--dangerously-skip-permissions)
    echo ">> permissions: SKIPPED (agent runs unrestricted; use --safe to prompt)" >&2
else
    echo ">> permissions: prompting (--safe)" >&2
fi
# Append passthrough args after the default flag. The ${arr[@]+…} guard keeps
# an empty array from tripping `set -u` on macOS bash 3.2.
claude_cmd+=(${claude_args[@]+"${claude_args[@]}"})

docker run "${run_args[@]}" "$IMAGE" ${claude_cmd[@]+"${claude_cmd[@]}"}
